---
---
<section class="py-16 md:py-24 bg-transparent relative overflow-hidden" id="about">
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#0A1F1C] rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[#D4AF37] rounded-full blur-[150px] opacity-10"></div>
  </div>

  <div class="container mx-auto px-4 md:px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center about-content flex flex-col gap-12 md:gap-16">
      
      <!-- Section 1 -->
      <div class="flex flex-col items-center">
        <div class="inline-flex items-center gap-4 mb-6 justify-center w-full">
          <div class="h-[1px] w-12 bg-[#D4AF37]/50"></div>
          <span class="text-[#D4AF37] uppercase tracking-[0.2em] text-sm font-medium">The Auyvra Experience</span>
          <div class="h-[1px] w-12 bg-[#D4AF37]/50"></div>
        </div>
        
        <h2 class="text-3xl md:text-5xl font-serif text-[#FDFBF7] mb-6 leading-tight">
          Luxury Spa in Hyderabad for <span class="text-gradient-gold">Complete Wellness & Relaxation</span>
        </h2>
        
        <p class="text-base md:text-lg text-[#FDFBF7]/70 font-light leading-relaxed max-w-3xl">
          Auyvra Spa is a luxury spa in Hyderabad offering premium wellness experiences designed to help you relax, recharge and rejuvenate. Our expert therapists provide personalized spa treatments and full body massage services in Hyderabad using professional techniques and a tranquil environment. Whether you need stress relief, muscle relaxation or a premium spa and massage experience in Hyderabad, we are committed to delivering exceptional care and comfort.
        </p>
      </div>

      <!-- Section 2 -->
      <div class="flex flex-col items-center">
        <h2 class="text-2xl md:text-4xl font-serif text-[#FDFBF7] mb-6 leading-tight">
          Looking For A <span class="text-[#D4AF37]">Spa Near Me</span> In Hyderabad?
        </h2>
        
        <p class="text-base md:text-lg text-[#FDFBF7]/70 font-light leading-relaxed max-w-3xl mb-8">
          If you are searching for a spa near me, massage center near me, best spas near me or luxury spa near me, Auyvra Spa is conveniently located in Hyderabad and easily accessible from Moosapet, Kukatpally, Erragadda, Bharat Nagar, Ameerpet, SR Nagar and nearby areas. Our location, professional therapists and premium facilities make us a preferred choice for guests looking for quality spa services near their location.
        </p>

        <a href="#services" class="inline-flex items-center gap-2 text-[#D4AF37] hover:text-[#F3E5AB] transition-colors border-b border-[#D4AF37]/30 hover:border-[#F3E5AB] pb-1 uppercase tracking-widest text-sm font-medium">
          Reserve Your Relaxation Experience
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Bypassed on mobile to optimize load times and TBT
  if (window.innerWidth >= 768) {
    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(".about-content > *", 
      { y: 50, opacity: 0 },
      { 
        y: 0, 
        opacity: 1, 
        duration: 1, 
        stagger: 0.2, 
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#about",
          start: "top 75%",
        }
      }
    );
  }
</script>

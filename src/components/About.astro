---
---
<section class="py-16 md:py-24 bg-transparent relative overflow-hidden" id="about">
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#0A1F1C] rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[#D4AF37] rounded-full blur-[150px] opacity-10"></div>
  </div>

  <div class="container mx-auto px-4 md:px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center about-content">
      <div class="inline-flex items-center gap-4 mb-8 justify-center w-full">
        <div class="h-[1px] w-12 bg-[#D4AF37]/50"></div>
        <span class="text-[#D4AF37] uppercase tracking-[0.2em] text-sm font-medium">The Auyvra Experience</span>
        <div class="h-[1px] w-12 bg-[#D4AF37]/50"></div>
      </div>
      
      <h2 class="text-3xl md:text-5xl font-serif text-[#FDFBF7] mb-10 leading-tight">
        A Luxury Spa Hyderabad Experience for Those Who Seek <span class="text-gradient-gold">More Than a Massage</span>
      </h2>
      
      <p class="text-lg md:text-xl text-[#FDFBF7]/70 font-light leading-relaxed mb-8">
        Auyvra Luxury Spa center is a destination for those who value comfort, relaxation, and exceptional wellness experiences. Every detail, from our tranquil atmosphere to our personalized treatments, is thoughtfully designed to deliver an elevated spa journey.
      </p>
      
      <p class="text-base md:text-lg text-[#FDFBF7]/60 font-light leading-relaxed mb-12">
        Whether you're seeking a restorative body massage Hyderabad treatment, professional massage Hyderabad therapies, or a premium spa and massage Hyderabad experience, our team is dedicated to helping you achieve complete relaxation and well-being. As a trusted spa center, we create experiences that help you escape the demands of daily life and embrace a renewed sense of balance.
      </p>

      <a href="#services" class="inline-flex items-center gap-2 text-[#D4AF37] hover:text-[#F3E5AB] transition-colors border-b border-[#D4AF37]/30 hover:border-[#F3E5AB] pb-1 uppercase tracking-widest text-sm font-medium">
        Reserve Your Relaxation Experience
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(".about-content > *", 
    { y: 50, opacity: 0 },
    { 
      y: 0, 
      opacity: 1, 
      duration: 1, 
      stagger: 0.2, 
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#about",
        start: "top 75%",
      }
    }
  );
</script>

---
---
<section class="py-16 md:py-24 bg-transparent relative overflow-hidden" id="about">
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#0A1F1C] rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[#D4AF37] rounded-full blur-[150px] opacity-10"></div>
  </div>

  <div class="container mx-auto px-4 md:px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center about-content">
      
      <!-- Section 1 -->
      <div class="flex flex-col items-center">
        <div class="inline-flex items-center gap-4 mb-6 justify-center w-full">
          <div class="h-[1px] w-12 bg-[#D4AF37]/50"></div>
          <span class="text-[#D4AF37] uppercase tracking-[0.2em] text-sm font-medium">The Auyvra Experience</span>
          <div class="h-[1px] w-12 bg-[#D4AF37]/50"></div>
        </div>
        
        <h2 class="text-3xl md:text-5xl font-serif text-[#FDFBF7] mb-6 leading-tight">
          Luxury Spa in Hyderabad – Premium <span class="text-gradient-gold">Hyderabad Spa Centre</span> for Wellness & Relaxation
        </h2>
        
        <p class="text-base md:text-lg text-[#FDFBF7]/70 font-light leading-relaxed max-w-3xl">
          Auyvra Spa is a premier Hyderabad spa centre offering premium wellness experiences designed to help you relax, recharge and rejuvenate. Our expert therapists provide personalized spa treatments and full body massage services in Hyderabad using professional techniques and a tranquil environment. Whether you need stress relief, muscle relaxation or a premium spa and massage experience in Hyderabad, we are committed to delivering exceptional care and comfort.
        </p>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Bypassed on mobile to optimize load times and TBT
  if (window.innerWidth >= 768) {
    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(".about-content > *", 
      { y: 50, opacity: 0 },
      { 
        y: 0, 
        opacity: 1, 
        duration: 1, 
        stagger: 0.2, 
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#about",
          start: "top 75%",
        }
      }
    );
  }
</script>

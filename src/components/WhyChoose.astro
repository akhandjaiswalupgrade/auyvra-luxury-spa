---
const reasons = [
  {
    title: "Professional Therapists",
    description: "Our certified and highly trained experts specialize in delivering the perfect touch for your body's recovery."
  },
  {
    title: "Premium Luxury Ambience",
    description: "Relax in an exquisitely designed sanctuary with ambient lighting, soothing soundscapes, and calming aromas."
  },
  {
    title: "Hygienic Treatment Rooms",
    description: "We maintain pristine cleanliness and sanitization standards across all rooms for your complete safety."
  },
  {
    title: "Personalized Wellness Experience",
    description: "Every session is tailored specifically to address your physical tension areas and wellness goals."
  },
  {
    title: "Convenient Hyderabad Location",
    description: "Easily accessible, located on Green Hills Road, making your wellness journey convenient."
  },
  {
    title: "Easy WhatsApp & Phone Booking",
    description: "Instantly reserve your preferred time slot and check therapist availability via message or call."
  },
  {
    title: "Experienced Wellness Specialists",
    description: "Deep knowledge of traditional Thai, Swedish, Deep Tissue, and custom aromatherapy techniques."
  },
  {
    title: "Relaxing & Private Treatment Environment",
    description: "Enjoy absolute privacy in our VIP rooms designed to give you a peaceful escape from everyday stress."
  }
];
---

<section class="py-16 md:py-24 bg-transparent relative border-t border-[#1a1a1a]" id="why-choose">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-16 font-serif">
      <h2 class="text-3xl md:text-5xl font-serif text-[#FDFBF7] mb-6 leading-tight">Why We Are Considered One Of The <span class="text-[#D4AF37]">Best Spas In Hyderabad</span></h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {reasons.map((reason, i) => (
        <div class="glass-panel p-8 rounded-2xl hover:-translate-y-2 transition-transform duration-500 group reason-card opacity-0">
          <div class="w-12 h-12 rounded-full bg-[#D4AF37]/10 flex items-center justify-center mb-6 border border-[#D4AF37]/20 group-hover:bg-[#D4AF37]/20 transition-colors">
            <span class="text-[#D4AF37] font-serif text-xl">{i + 1}</span>
          </div>
          <h3 class="text-xl font-serif text-[#FDFBF7] mb-3 leading-tight">{reason.title}</h3>
          <p class="text-[#FDFBF7]/60 font-light leading-relaxed text-sm">
            {reason.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Bypassed on mobile to optimize load times and TBT
  if (window.innerWidth >= 768) {
    gsap.registerPlugin(ScrollTrigger);

    gsap.to(".reason-card", {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.1,
      ease: "power2.out",
      scrollTrigger: {
        trigger: "#why-choose",
        start: "top 85%",
      }
    });
  }
</script>

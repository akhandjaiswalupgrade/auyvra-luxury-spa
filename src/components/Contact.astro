---
import { siteConfig } from '../data/site';
---

<section class="py-16 md:py-24 bg-transparent relative" id="contact">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-serif text-[#FDFBF7] mb-6">Book Your Luxury Spa Experience Today</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
      
      {/* Contact Info Cards */}
      <div class="flex flex-col justify-center space-y-6">
        <div class="glass-panel p-8 rounded-2xl flex items-start gap-6 hover:border-[#D4AF37]/40 transition-colors">
          <div class="w-12 h-12 rounded-full bg-[#D4AF37]/10 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-serif text-[#FDFBF7] mb-2">Contact Us</h3>
            <p class="text-[#FDFBF7]/60 font-light mb-4 text-lg">{siteConfig.phoneDisplay}</p>
            <div class="flex gap-4">
              <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-[#D4AF37] hover:text-[#F3E5AB] flex items-center gap-1 border-b border-[#D4AF37]/30 pb-0.5">WhatsApp Us</a>
              <a href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} class="text-sm font-medium text-[#D4AF37] hover:text-[#F3E5AB] flex items-center gap-1 border-b border-[#D4AF37]/30 pb-0.5">Call Now</a>
            </div>
          </div>
        </div>

        <div class="glass-panel p-8 rounded-2xl flex items-start gap-6 hover:border-[#D4AF37]/40 transition-colors">
          <div class="w-12 h-12 rounded-full bg-[#D4AF37]/10 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-serif text-[#FDFBF7] mb-2">Location</h3>
            <p class="text-[#FDFBF7]/60 font-light leading-relaxed mb-4 text-base">
              {siteConfig.address}
            </p>
            <a href={siteConfig.mapsUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-[#D4AF37] hover:text-[#F3E5AB] flex items-center gap-1 border-b border-[#D4AF37]/30 pb-0.5 w-fit">Get Directions on Maps</a>
          </div>
        </div>

        <div class="glass-panel p-8 rounded-2xl flex items-start gap-6 hover:border-[#D4AF37]/40 transition-colors">
          <div class="w-12 h-12 rounded-full bg-[#D4AF37]/10 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-serif text-[#FDFBF7] mb-2">Timings</h3>
            <p class="text-[#FDFBF7]/60 font-light text-lg">{siteConfig.timings}</p>
          </div>
        </div>
      </div>

      {/* Interactive Map Embed */}
      <div class="w-full h-full min-h-[400px] rounded-2xl overflow-hidden border border-[#D4AF37]/20 relative">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d60893.06295444928!2d78.3415857216797!3d17.4684979!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bcb9171b976fbab%3A0xd44444d0cd800447!2sAuyvra%20Luxury%20Spa!5e0!3m2!1sen!2sin!4v1781993422148!5m2!1sen!2sin" 
          width="100%" 
          height="100%" 
          style="border:0; min-height: 400px;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

    </div>
  </div>
</section>

---
import { siteConfig } from '../data/site';
---

<section class="relative min-h-[82dvh] md:h-[88dvh] w-full flex flex-col items-center justify-start overflow-hidden pt-32 pb-6 md:pt-26 md:pb-8" id="hero" style="perspective: 1000px;">
  
  <!-- Background Video with Parallax & 3D -->
  <div class="absolute inset-0 w-full h-full transform-origin-center" id="hero-bg">
    <!-- Desktop Background Video -->
    <video 
      src="/hero-bg.mp4" 
      class="hidden md:block object-cover w-full h-full object-[center_30%]"
      autoplay
      loop
      muted
      playsinline
      poster="/images/generated/hero_luxury_spa_hyderabad.png"
    ></video>
    <!-- Mobile Background Video -->
    <video 
      src="/hero-bg-mobile.mp4" 
      class="block md:hidden object-cover w-full h-full object-[center_30%]"
      autoplay
      loop
      muted
      playsinline
      poster="/images/generated/hero_luxury_spa_hyderabad.png"
    ></video>
    <!-- Simple transparent black overlay for text readability, slightly darker on mobile -->
    <div class="absolute inset-0 bg-black/45 md:bg-black/35 z-10"></div>
  </div>

  <!-- Mist overlay -->
  <div class="absolute inset-0 z-20 opacity-30 pointer-events-none mix-blend-screen" id="mist-overlay">
    <img src="/images/generated/abstract_mist_overlay.png" alt="" class="object-cover w-full h-full opacity-50" />
  </div>

  <!-- Content Container (Single Flex Column) -->
  <div class="relative z-20 text-center px-4 md:px-6 w-full max-w-5xl mx-auto flex flex-col items-center justify-center gap-4 md:gap-5">
    
    <div class="flex flex-col items-center justify-center gap-2.5">
      <div class="overflow-hidden">
        <span class="block text-sm md:text-base tracking-[0.2em] text-[#D4AF37] uppercase font-medium hero-text" style="filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.7));">Welcome to Auyvra Luxury Spa</span>
      </div>
      
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-serif text-[#FDFBF7] max-w-4xl mx-auto leading-[1.15] tracking-tight hero-text" style="filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.9)) drop-shadow(0 2px 4px rgba(0, 0, 0, 0.8));">
        Best Spa in Hyderabad for <span class="text-gradient-gold">Relaxation & Body Massage</span>
      </h1>
      
      <p class="text-sm sm:text-base md:text-lg text-[#FDFBF7]/90 max-w-2xl hero-text font-normal mt-2 leading-relaxed" style="filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.9));">
        Experience premium spa Hyderabad services, expert body massage therapies, and luxury wellness treatments designed to help you relax, rejuvenate, and restore balance to your body and mind.
      </p>
    </div>

    <!-- Buttons Centered Row -->
    <div class="flex flex-row items-center justify-center gap-3 hero-text mt-2 w-full">
      <a 
        href={`https://wa.me/917386542499?text=Hi%20Auyvra%20Luxury%20Spa,%20I%20want%20to%20book%20an%20appointment.`}
        target="_blank"
        rel="noopener noreferrer"
        class="glass-button flex items-center justify-center gap-2 px-5 py-2.5 md:px-8 md:py-3.5 rounded-full bg-[#075E54] hover:bg-[#05433c] text-white transition-all duration-300 transform hover:scale-105"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.66.986 3.292 1.48 4.832 1.48 5.176 0 9.387-4.208 9.39-9.386.002-2.509-.974-4.866-2.748-6.64-1.77-1.776-4.127-2.753-6.637-2.754-5.183 0-9.395 4.209-9.399 9.391-.001 1.623.42 3.202 1.22 4.606l-.993 3.628 3.735-.98zm11.117-6.425c-.299-.149-1.773-.875-2.046-.975-.275-.1-.475-.149-.675.15-.2.299-.774.975-.95 1.174-.175.2-.35.224-.65.074-1.86-.93-2.934-1.614-4.103-3.62-.3-.516.3-.479.858-1.597.09-.18.045-.337-.023-.487-.067-.15-.575-1.387-.787-1.9-.207-.5-.436-.433-.6-.442l-.51-.009c-.175 0-.46.065-.7.325-.24.26-1.127 1.102-1.127 2.686 0 1.584 1.152 3.118 1.31 3.328.16.208 2.266 3.46 5.49 4.856.766.332 1.364.53 1.83.678.77.244 1.47.21 2.025.127.619-.092 1.773-.724 2.023-1.424.25-.699.25-1.3.175-1.424-.075-.125-.275-.199-.575-.349z"/></svg>
        <span class="font-medium tracking-wide text-xs sm:text-sm md:text-base" style="text-shadow: 0 1px 2px rgba(0,0,0,0.8);">WhatsApp</span>
      </a>

      <a 
        href={`tel:+917386542499`}
        class="glass-button flex items-center justify-center gap-2 px-5 py-2.5 md:px-8 md:py-3.5 rounded-full bg-[#D4AF37] hover:bg-[#FDFBF7] text-[#0a0a0a] transition-all duration-300 transform hover:scale-105"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="font-medium tracking-wide text-xs sm:text-sm md:text-base">Call Now</span>
      </a>
    </div>

    <!-- Trust Badges -->
    <div class="flex flex-wrap justify-center gap-4 md:gap-8 text-xs sm:text-sm md:text-base text-[#FDFBF7]/70 font-light hero-text mt-2">
      <div class="flex items-center gap-1.5">
        <div class="w-1.5 h-1.5 rounded-full bg-[#D4AF37]"></div>
        Premium Spa in Hyderabad
      </div>
      <div class="flex items-center gap-1.5">
        <div class="w-1.5 h-1.5 rounded-full bg-[#D4AF37]"></div>
        Moosapet Location
      </div>
      <div class="flex items-center gap-1.5">
        <div class="w-1.5 h-1.5 rounded-full bg-[#D4AF37]"></div>
        VIP & VVIP Experiences
      </div>
    </div>
    
    <!-- Scroll Indicator Centered -->
    <div class="flex flex-col items-center gap-1 hero-text mt-3">
      <span class="text-[#D4AF37] text-xs font-medium tracking-[0.2em] uppercase">Scroll</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Initial Load Animation
  const tl = gsap.timeline();
  
  tl.fromTo("#hero-bg", 
    { scale: 1.02, filter: "blur(8px)" }, 
    { scale: 1, filter: "blur(0px)", duration: 2, ease: "power3.out" }
  )
  .fromTo(".hero-text", 
    { y: 20, opacity: 0 }, 
    { y: 0, opacity: 1, duration: 1, stagger: 0.12, ease: "power3.out" },
    "-=1.2"
  );

  // Fade out background on scroll
  gsap.to("#hero-bg", {
    opacity: 0.45,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "top top",
      end: "bottom top",
      scrub: 1
    }
  });

  // Mist animation (continuous subtle movement)
  gsap.to("#mist-overlay", {
    x: "-3%",
    y: "3%",
    scale: 1.05,
    duration: 15,
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut"
  });

  // Programmatic play for both background videos to prevent browser blocks or pauses
  const videos = document.querySelectorAll('#hero-bg video') as NodeListOf<HTMLVideoElement>;
  videos.forEach(video => {
    if (video) {
      const playVideo = () => {
        if (video.paused) {
          video.play().catch(err => console.warn("Video play interrupted:", err));
        }
      };
      
      // Attempt playback on load
      playVideo();

      // Bind interaction fallback in case of block
      const handleInteraction = () => {
        playVideo();
        document.removeEventListener('click', handleInteraction);
        document.removeEventListener('touchstart', handleInteraction);
      };

      document.addEventListener('click', handleInteraction);
      document.addEventListener('touchstart', handleInteraction);
    }
  });
</script>

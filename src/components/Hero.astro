---
import { siteConfig } from '../data/site';
---

<section class="relative min-h-[100dvh] w-full flex flex-col items-center justify-start overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24" id="hero" style="perspective: 1000px;">
  
  <!-- Background Image with Parallax & 3D (LCP Optimized with Responsive WebP) -->
  <div class="absolute inset-0 w-full h-full transform-origin-center z-0" id="hero-bg">
    <picture>
      <source srcset="/images/generated/hero_luxury_spa_hyderabad_mobile.webp" media="(max-width: 768px)" type="image/webp" />
      <source srcset="/images/generated/hero_luxury_spa_hyderabad.webp" type="image/webp" />
      <img 
        src="/images/generated/hero_luxury_spa_hyderabad.png" 
        alt="Auyvra Luxury Spa Hyderabad Background" 
        class="object-cover w-full h-full object-[center_30%]"
        loading="eager"
        fetchpriority="high"
      />
    </picture>
    <!-- Simple transparent black overlay for text readability, slightly darker on mobile -->
    <div class="absolute inset-0 bg-black/45 md:bg-black/35 z-10"></div>
  </div>

  <!-- Mist overlay (Optimized WebP) -->
  <div class="absolute inset-0 z-10 opacity-30 pointer-events-none mix-blend-screen" id="mist-overlay">
    <img src="/images/generated/abstract_mist_overlay.webp" alt="" class="object-cover w-full h-full opacity-50" />
  </div>

  <!-- Content Container (Single Flex Column) -->
  <div class="relative z-20 text-center px-4 md:px-6 w-full max-w-5xl mx-auto flex-1 flex flex-col justify-between items-center gap-8">
    
    <!-- Top Block: Welcome & Title -->
    <div class="flex flex-col items-center gap-4 w-full">
      <div class="overflow-hidden">
        <span class="block text-sm md:text-base tracking-[0.25em] text-[#D4AF37] uppercase font-semibold hero-text" style="filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.7));">Welcome to Auyvra Luxury Spa</span>
      </div>
      
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-serif text-[#FDFBF7] max-w-4xl mx-auto leading-[1.2] tracking-tight hero-text" style="filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.9)) drop-shadow(0 2px 4px rgba(0, 0, 0, 0.8));">
        Best Spa in Hyderabad for <span class="text-gradient-gold">Luxury Relaxation & Full Body Massage</span>
      </h1>
    </div>

    <!-- Middle Block: Description & CTA Buttons -->
    <div class="flex flex-col items-center gap-6 w-full max-w-3xl my-auto">
      <p class="text-base sm:text-lg md:text-xl text-[#FDFBF7]/95 max-w-3xl hero-text font-normal leading-relaxed" style="filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.9));">
        Looking for a premium **body massage and spa near me**? Auyvra Spa is a premier **hyderabad massage spa** offering full body massage, wellness therapies and rejuvenating spa experiences in Hyderabad. Conveniently located for guests searching for a spa near me, massage center near me or luxury spa near me.
      </p>

      <!-- Buttons Centered Row -->
      <div class="flex flex-wrap items-center justify-center gap-3.5 hero-text w-full">
        <a 
          href="#booking-form"
          class="glass-button flex items-center justify-center gap-2 px-6 py-3.5 md:px-8 md:py-4 rounded-full bg-[#D4AF37] hover:bg-[#FDFBF7] text-[#0a0a0a] transition-all duration-300 transform hover:scale-105"
        >
          <span class="font-medium tracking-wide text-sm md:text-base">Book Appointment</span>
        </a>

        <a 
          href={`https://wa.me/917386542499?text=Hi%20Auyvra%20Luxury%20Spa,%20I%20want%20to%20book%20an%20appointment.`}
          target="_blank"
          rel="noopener noreferrer"
          class="glass-button flex items-center justify-center gap-2 px-6 py-3.5 md:px-8 md:py-4 rounded-full bg-[#075E54] hover:bg-[#05433c] text-white transition-all duration-300 transform hover:scale-105"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.66.986 3.292 1.48 4.832 1.48 5.176 0 9.387-4.208 9.39-9.386.002-2.509-.974-4.866-2.748-6.64-1.77-1.776-4.127-2.753-6.637-2.754-5.183 0-9.395 4.209-9.399 9.391-.001 1.623.42 3.202 1.22 4.606l-.993 3.628 3.735-.98zm11.117-6.425c-.299-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          <span class="font-medium tracking-wide text-sm md:text-base" style="text-shadow: 0 1px 2px rgba(0,0,0,0.8);">WhatsApp</span>
        </a>

        <a 
          href={`tel:+917386542499`}
          class="glass-button flex items-center justify-center gap-2 px-6 py-3.5 md:px-8 md:py-4 rounded-full border border-[#D4AF37] text-[#D4AF37] hover:bg-[#D4AF37]/10 transition-all duration-300 transform hover:scale-105"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span class="font-medium tracking-wide text-sm md:text-base">Call Now</span>
        </a>
      </div>
    </div>

    <!-- Bottom Block: Trust Badges (Glassmorphic Boxes with Larger Fonts) -->
    <div class="flex flex-col items-center gap-4 w-full mt-auto pb-4">
      <div class="flex flex-wrap justify-center gap-3.5 text-xs sm:text-sm md:text-base text-[#FDFBF7]/90 font-medium hero-text">
        <div class="px-4 py-2 rounded-full border border-[#D4AF37]/15 bg-[#D4AF37]/5 backdrop-blur-sm shadow-[0_2px_8px_rgba(0,0,0,0.4)] flex items-center gap-2">
          <span class="text-[#D4AF37] text-xs font-semibold">✦</span>
          Premium Spa in Hyderabad
        </div>
        <div class="px-4 py-2 rounded-full border border-[#D4AF37]/15 bg-[#D4AF37]/5 backdrop-blur-sm shadow-[0_2px_8px_rgba(0,0,0,0.4)] flex items-center gap-2">
          <span class="text-[#D4AF37] text-xs font-semibold">✦</span>
          Moosapet Location
        </div>
        <div class="px-4 py-2 rounded-full border border-[#D4AF37]/15 bg-[#D4AF37]/5 backdrop-blur-sm shadow-[0_2px_8px_rgba(0,0,0,0.4)] flex items-center gap-2">
          <span class="text-[#D4AF37] text-xs font-semibold">✦</span>
          VIP & VVIP Experiences
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator Centered at Bottom -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-1 hero-text">
    <span class="text-[#D4AF37] text-xs font-medium tracking-[0.2em] uppercase">Scroll</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Bypassed on mobile to optimize load times and TBT
  if (window.innerWidth >= 768) {
    gsap.registerPlugin(ScrollTrigger);

    // Initial Load Animation
    const tl = gsap.timeline();
    
    tl.fromTo("#hero-bg", 
      { scale: 1.02, filter: "blur(8px)" }, 
      { scale: 1, filter: "blur(0px)", duration: 2, ease: "power3.out" }
    )
    .fromTo(".hero-text", 
      { y: 20, opacity: 0 }, 
      { y: 0, opacity: 1, duration: 1, stagger: 0.12, ease: "power3.out" },
      "-=1.2"
    );

    // Fade out background on scroll
    gsap.to("#hero-bg", {
      opacity: 0.45,
      ease: "none",
      scrollTrigger: {
        trigger: "#hero",
        start: "top top",
        end: "bottom top",
        scrub: 1
      }
    });

    // Mist animation (continuous subtle movement)
    gsap.to("#mist-overlay", {
      x: "-3%",
      y: "3%",
      scale: 1.05,
      duration: 15,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });
  }
</script>

---
import { siteConfig } from '../data/site';
---

<section class="relative h-[90dvh] md:h-[88dvh] w-full flex flex-col items-center justify-center overflow-hidden pt-28 pb-8 md:pt-32 md:pb-12" id="hero" style="perspective: 1000px;">
  
  <!-- Background Video with Parallax & 3D -->
  <div class="absolute inset-0 w-full h-full transform-origin-center" id="hero-bg">
    <video 
      src="/hero-bg.mp4" 
      class="object-cover w-full h-full object-[center_30%]"
      autoplay
      loop
      muted
      playsinline
      poster="/images/generated/hero_luxury_spa_hyderabad.png"
    ></video>
    <!-- Simple transparent black overlay for text readability -->
    <div class="absolute inset-0 bg-black/30 z-10"></div>
  </div>

  <!-- Mist overlay -->
  <div class="absolute inset-0 z-20 opacity-30 pointer-events-none mix-blend-screen" id="mist-overlay">
    <img src="/images/generated/abstract_mist_overlay.png" alt="" class="object-cover w-full h-full opacity-50" />
  </div>

  <!-- Content Container (Single Flex Column) -->
  <div class="relative z-20 text-center px-4 md:px-6 w-full max-w-5xl mx-auto flex flex-col items-center justify-center gap-6 md:gap-8">
    
    <div class="flex flex-col items-center justify-center gap-3">
      <div class="overflow-hidden">
        <span class="block text-sm md:text-base tracking-[0.2em] text-[#D4AF37] uppercase font-medium hero-text">Welcome to Auyvra Luxury Spa</span>
      </div>
      
      <h1 class="text-3xl md:text-6xl lg:text-7xl font-serif text-[#FDFBF7] max-w-4xl mx-auto leading-[1.1] tracking-tight hero-text">
        Experience <span class="text-gradient-gold">Luxury Wellness</span> in the Heart of Hyderabad
      </h1>
      
      <p class="text-sm md:text-xl text-[#FDFBF7]/80 max-w-2xl hero-text font-light mt-1 leading-snug">
        Auyvra Luxury Spa brings premium massage therapies, VIP spa rooms, hammam rituals, jacuzzi experiences, and deep relaxation together in one luxury wellness destination in Moosapet.
      </p>
    </div>

    <!-- Buttons Centered Row -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 hero-text mt-2">
      <a 
        href={`https://wa.me/917386542499?text=Hi%20Auyvra%20Luxury%20Spa,%20I%20want%20to%20book%20an%20appointment.`}
        target="_blank"
        rel="noopener noreferrer"
        class="glass-button flex items-center gap-3 px-6 md:px-8 py-3 md:py-4 rounded-full bg-[#D4AF37] hover:bg-[#FDFBF7] text-[#0a0a0a] transition-all duration-300 transform hover:scale-105"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="font-medium tracking-wide text-sm md:text-base">Book on WhatsApp</span>
      </a>

      <a 
        href={`tel:+917386542499`}
        class="glass-button flex items-center gap-3 px-6 md:px-8 py-3 md:py-4 rounded-full border border-[#D4AF37] text-[#D4AF37] hover:bg-[#D4AF37] hover:text-[#0a0a0a] transition-all duration-300 transform hover:scale-105"
      >
        <span class="font-medium tracking-wide text-sm md:text-base">Call Now</span>
      </a>
    </div>

    <!-- Trust Badges -->
    <div class="flex flex-wrap justify-center gap-4 md:gap-10 text-xs md:text-base text-[#FDFBF7]/60 font-light hero-text mt-2">
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-1.5 rounded-full bg-[#D4AF37]"></div>
        Premium Spa in Hyderabad
      </div>
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-1.5 rounded-full bg-[#D4AF37]"></div>
        Moosapet Location
      </div>
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-1.5 rounded-full bg-[#D4AF37]"></div>
        VIP & VVIP Experiences
      </div>
    </div>
    
    <!-- Scroll Indicator Centered -->
    <div class="flex flex-col items-center gap-2 hero-text mt-4">
      <span class="text-[#D4AF37] text-xs font-medium tracking-[0.2em] uppercase">Scroll</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Initial Load Animation
  const tl = gsap.timeline();
  
  tl.fromTo("#hero-bg", 
    { scale: 1.02, filter: "blur(8px)" }, 
    { scale: 1, filter: "blur(0px)", duration: 2, ease: "power3.out" }
  )
  .fromTo(".hero-text", 
    { y: 20, opacity: 0 }, 
    { y: 0, opacity: 1, duration: 1, stagger: 0.12, ease: "power3.out" },
    "-=1.2"
  );

  // Fade out background on scroll
  gsap.to("#hero-bg", {
    opacity: 0.45,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "top top",
      end: "bottom top",
      scrub: 1
    }
  });

  // Mist animation (continuous subtle movement)
  gsap.to("#mist-overlay", {
    x: "-3%",
    y: "3%",
    scale: 1.05,
    duration: 15,
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut"
  });

  // Programmatic play for the background video to prevent browser blocks or pauses
  const video = document.querySelector('#hero-bg video') as HTMLVideoElement;
  if (video) {
    const playVideo = () => {
      if (video.paused) {
        video.play().catch(err => console.warn("Video play interrupted:", err));
      }
    };
    
    // Attempt playback on load
    playVideo();

    // Bind interaction fallback in case of block
    const handleInteraction = () => {
      playVideo();
      document.removeEventListener('click', handleInteraction);
      document.removeEventListener('touchstart', handleInteraction);
    };

    document.addEventListener('click', handleInteraction);
    document.addEventListener('touchstart', handleInteraction);
  }
</script>

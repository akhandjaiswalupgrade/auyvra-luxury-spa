---
import { siteConfig } from '../data/site';
---

<section class="relative py-20 md:py-32 bg-[#0a0a0a] overflow-hidden flex items-center justify-center" id="booking-push">
  <!-- Background -->
  <div class="absolute inset-0 w-full h-full">
    <img 
      src="/images/generated/gold_luxury_texture.png" 
      alt="Gold Texture" 
      class="object-cover w-full h-full opacity-30 mix-blend-color-dodge booking-bg"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/80 to-[#0a0a0a]"></div>
  </div>

  <div class="container mx-auto px-4 md:px-6 relative z-10 text-center max-w-4xl">
    <h2 class="text-3xl md:text-5xl lg:text-6xl font-serif text-[#FDFBF7] mb-8 leading-tight booking-content opacity-0 translate-y-8">
      Escape the Stress of Everyday Life.<br />
      <span class="text-gradient-gold">Book Your Spa and Massage Hyderabad Experience.</span>
    </h2>
    
    <p class="text-lg text-[#FDFBF7]/80 font-light leading-relaxed mb-12 max-w-2xl mx-auto booking-content opacity-0 translate-y-8">
      Experience premium body massage therapies, personalized wellness treatments, and exceptional care in a setting designed for comfort, relaxation, and rejuvenation.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 booking-content opacity-0 translate-y-8">
      <a 
        href={siteConfig.whatsappUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class="group relative inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#D4AF37] text-[#0a0a0a] font-medium rounded-full overflow-hidden transition-all hover:scale-105 shadow-[0_0_30px_rgba(212,175,55,0.3)] w-full sm:w-auto"
      >
        <svg class="w-5 h-5 relative z-10" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        <span class="relative z-10">Book on WhatsApp</span>
        <div class="absolute inset-0 bg-white/20 transform -translate-x-full group-hover:translate-x-0 transition-transform duration-500 ease-out z-0"></div>
      </a>
      
      <a 
        href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} 
        class="inline-flex items-center justify-center px-8 py-4 bg-transparent border border-[#D4AF37] text-[#D4AF37] font-medium rounded-full hover:bg-[#D4AF37]/10 transition-colors w-full sm:w-auto"
      >
        Call for Appointment
      </a>

      <a 
        href={siteConfig.mapsUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 text-[#FDFBF7]/70 hover:text-[#D4AF37] transition-colors border-b border-transparent hover:border-[#D4AF37] pb-1 font-medium w-full sm:w-auto mt-4 sm:mt-0"
      >
        Get Directions
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.to(".booking-bg", {
    yPercent: 20,
    ease: "none",
    scrollTrigger: {
      trigger: ".booking-bg",
      start: "top bottom",
      end: "bottom top",
      scrub: true
    }
  });

  gsap.to(".booking-content", {
    y: 0,
    opacity: 1,
    duration: 1,
    stagger: 0.2,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#booking-push",
      start: "top 80%",
    }
  });
</script>

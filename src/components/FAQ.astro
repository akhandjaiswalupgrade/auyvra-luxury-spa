---
const faqs = [
  {
    q: "Which is the best spa in Hyderabad?",
    a: "Auyvra Spa offers premium wellness therapies, luxury spa treatments and full body massage services designed to provide complete relaxation and rejuvenation in a comfortable and professional environment."
  },
  {
    q: "Do you provide full body massage in Hyderabad?",
    a: "Yes. We offer professional full body massage therapies along with a variety of wellness and relaxation treatments designed to reduce stress, improve comfort and support overall wellbeing."
  },
  {
    q: "Where can I find a luxury spa near me?",
    a: "Auyvra Spa is conveniently located in Hyderabad and easily accessible from Moosapet, Kukatpally, Erragadda, Bharat Nagar, Ameerpet, SR Nagar and nearby locations."
  },
  {
    q: "Is your massage center near Kukatpally and Moosapet?",
    a: "Yes. Our spa is conveniently located for guests visiting from Kukatpally, Moosapet and surrounding Hyderabad areas."
  },
  {
    q: "What spa and massage services do you offer in Hyderabad?",
    a: "We offer full body massage, aroma therapy, wellness treatments and luxury spa experiences tailored to individual relaxation and rejuvenation needs."
  },
  {
    q: "Do you accept same-day spa bookings in Hyderabad?",
    a: "Yes. Subject to availability, we welcome same-day appointments and advance bookings through phone and WhatsApp."
  }
];
---

<section class="py-16 md:py-24 bg-transparent relative border-y border-[#1a1a1a]" id="faq">
  <div class="container mx-auto px-4 md:px-6 max-w-4xl">
    <div class="text-center mb-16">
      <span class="text-[#D4AF37] uppercase tracking-[0.2em] text-sm font-medium block mb-4">Answers</span>
      <h2 class="text-3xl md:text-5xl font-serif text-[#FDFBF7] leading-tight">Frequently Asked Questions</h2>
    </div>

    <div class="space-y-4" id="faq-accordion">
      {faqs.map((faq, index) => (
        <div 
          class={`faq-item border rounded-2xl overflow-hidden transition-all duration-300 ${index === 0 ? 'border-[#D4AF37]/50 bg-[#121212]' : 'border-[#1a1a1a] bg-[#0a0a0a] hover:border-[#D4AF37]/30'}`}
        >
          <button
            class="faq-trigger w-full text-left px-6 py-6 flex items-center justify-between focus:outline-none focus:ring-2 focus:ring-[#D4AF37]/50"
            data-index={index}
            aria-expanded={index === 0 ? "true" : "false"}
          >
            <span class="text-[#FDFBF7] font-medium pr-8 leading-snug">{faq.q}</span>
            <div
              class={`faq-chevron text-[#D4AF37] shrink-0 transition-transform duration-300 ${index === 0 ? 'rotate-180' : 'rotate-0'}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
          </button>
          
          <div
            class={`faq-content transition-all duration-300 ease-in-out ${index === 0 ? 'max-h-[500px] opacity-100' : 'max-h-0 opacity-0 pointer-events-none'}`}
          >
            <div class="px-6 pb-6 text-[#FDFBF7]/60 font-light leading-relaxed">
              {faq.a}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.faq-trigger');
  const items = document.querySelectorAll('.faq-item');
  const chevrons = document.querySelectorAll('.faq-chevron');
  const contents = document.querySelectorAll('.faq-content');

  triggers.forEach((trigger, i) => {
    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all items
      triggers.forEach((t, index) => {
        t.setAttribute('aria-expanded', 'false');
        items[index]?.classList.remove('border-[#D4AF37]/50', 'bg-[#121212]');
        items[index]?.classList.add('border-[#1a1a1a]', 'bg-[#0a0a0a]');
        chevrons[index]?.classList.remove('rotate-180');
        chevrons[index]?.classList.add('rotate-0');
        
        const content = contents[index] as HTMLElement;
        if (content) {
          content.classList.remove('opacity-100');
          content.classList.add('opacity-0', 'pointer-events-none');
          content.style.maxHeight = '0px';
        }
      });

      // Open clicked item if it was closed
      if (!isOpen) {
        trigger.setAttribute('aria-expanded', 'true');
        items[i]?.classList.add('border-[#D4AF37]/50', 'bg-[#121212]');
        items[i]?.classList.remove('border-[#1a1a1a]', 'bg-[#0a0a0a]');
        chevrons[i]?.classList.remove('rotate-0');
        chevrons[i]?.classList.add('rotate-180');
        
        const content = contents[i] as HTMLElement;
        if (content) {
          content.classList.remove('opacity-0', 'pointer-events-none');
          content.classList.add('opacity-100');
          content.style.maxHeight = '500px';
        }
      }
    });
  });
</script>

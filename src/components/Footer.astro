---
import { siteConfig } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="bg-[#050505] pt-16 md:pt-20 pb-28 md:pb-12 border-t border-[#1a1a1a] relative z-40">
  <div class="container mx-auto px-4 md:px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
      
      {/* Brand */}
      <div class="lg:col-span-1">
        <img src="/images/logo.png" alt="Auyvra Luxury Spa" class="h-28 w-auto object-contain mb-4" />
        <p class="text-[#FDFBF7]/60 font-light text-sm mb-6 leading-relaxed">
          Luxury wellness, relaxation, and rejuvenation in Hyderabad. Experience premium spa therapies tailored for your comfort.
        </p>
        <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-[#0a0a0a] bg-[#D4AF37] px-6 py-2.5 rounded-full hover:bg-[#F3E5AB] transition-colors">
          Book Appointment
        </a>
      </div>

      {/* Quick Links */}
      <div>
        <h3 class="text-[#FDFBF7] font-medium mb-6 uppercase tracking-widest text-sm">Quick Links</h3>
        <ul class="space-y-4 text-sm font-light text-[#FDFBF7]/60">
          <li><a href="#hero" class="hover:text-[#D4AF37] transition-colors">Home</a></li>
          <li><a href="#about" class="hover:text-[#D4AF37] transition-colors">The Experience</a></li>
          <li><a href="#services" class="hover:text-[#D4AF37] transition-colors">Spa Services</a></li>
          <li><a href="#contact" class="hover:text-[#D4AF37] transition-colors">Contact & Location</a></li>
        </ul>
      </div>

      {/* Services */}
      <div>
        <h3 class="text-[#FDFBF7] font-medium mb-6 uppercase tracking-widest text-sm">Premium Services</h3>
        <ul class="space-y-4 text-sm font-light text-[#FDFBF7]/60">
          <li><span class="hover:text-[#D4AF37] transition-colors cursor-pointer">VIP Signature Room</span></li>
          <li><span class="hover:text-[#D4AF37] transition-colors cursor-pointer">VIP Private Steam</span></li>
          <li><span class="hover:text-[#D4AF37] transition-colors cursor-pointer">Royal Jacuzzi</span></li>
          <li><span class="hover:text-[#D4AF37] transition-colors cursor-pointer">Aroma & Deep Tissue</span></li>
        </ul>
      </div>

      {/* Contact Info */}
      <div>
        <h3 class="text-[#FDFBF7] font-medium mb-6 uppercase tracking-widest text-sm">Reach Us</h3>
        <ul class="space-y-4 text-sm font-light text-[#FDFBF7]/60">
          <li class="flex gap-3">
            <span class="text-[#D4AF37] shrink-0">📍</span>
            <span>{siteConfig.address}</span>
          </li>
          <li class="flex gap-3">
            <span class="text-[#D4AF37] shrink-0">📞</span>
            <a href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} class="hover:text-[#D4AF37] transition-colors">{siteConfig.phoneDisplay}</a>
          </li>
          <li class="flex gap-3">
            <span class="text-[#D4AF37] shrink-0">⏰</span>
            <span>{siteConfig.timings}</span>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-[#1a1a1a] flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[#FDFBF7]/40">
        &copy; {year} Auyvra Luxury Spa. All rights reserved.
      </p>
      <p class="text-xs text-[#FDFBF7]/40">
        Made with <span class="text-red-500">❤️</span> by <a href="https://mevryx.com" target="_blank" rel="nofollow noopener noreferrer" class="text-[#D4AF37] hover:text-[#F3E5AB] transition-colors font-medium">Mevryx.com</a>
      </p>
      <p class="text-xs text-[#FDFBF7]/40 flex gap-4">
        <span class="hover:text-[#FDFBF7] transition-colors cursor-pointer">Privacy Policy</span>
        <span class="hover:text-[#FDFBF7] transition-colors cursor-pointer">Terms of Service</span>
      </p>
    </div>
  </div>
</footer>

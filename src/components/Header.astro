---
import { siteConfig } from '../data/site';

const navLinks = [
  { name: 'Experience', href: '/#about' },
  { name: 'Services', href: '/#services' },
  { name: 'Gallery', href: '/#gallery' },
  { name: 'FAQ', href: '/#faq' },
];
---

<header 
  id="main-header"
  class="fixed top-0 left-0 right-0 z-[100] transition-all duration-500 bg-transparent py-6"
>
  <div class="container mx-auto px-4 md:px-6 flex items-center justify-between">
    <a href="#" class="flex items-center gap-2 relative z-[101]">
      <img 
        src="/images/logo.webp" 
        alt="Auyvra Luxury Spa" 
        id="header-logo"
        class="w-auto object-contain transition-all duration-300 h-20 md:h-28" 
      />
    </a>

    {/* Desktop Nav */}
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="text-sm font-medium text-[#FDFBF7]/80 hover:text-[#D4AF37] transition-colors"
        >
          {link.name}
        </a>
      ))}
      <a 
        href="/#booking-form" 
        class="px-6 py-2 bg-[#D4AF37] hover:bg-[#F3E5AB] text-[#0a0a0a] text-sm font-medium rounded-full transition-all border border-transparent"
      >
        Book Appointment
      </a>
    </nav>

    {/* Mobile Toggle */}
    <button 
      id="mobile-menu-toggle"
      class="md:hidden relative z-[101] p-2 text-[#FDFBF7] focus:outline-none"
      aria-label="Toggle Menu"
    >
      <span class="sr-only">Toggle Menu</span>
      <!-- Hamburger Icon -->
      <svg id="hamburger-icon" class="w-7 h-7 block" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <!-- X Close Icon -->
      <svg id="close-icon" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</header>

{/* Mobile Menu Overlay */}
<div 
  id="mobile-menu-overlay"
  class="fixed inset-0 z-[99] bg-[#0a0a0a] flex flex-col pt-32 px-6 pb-6 transition-all duration-500 transform -translate-y-full opacity-0 pointer-events-none"
>
  <nav class="flex flex-col gap-6 items-center justify-center flex-1">
    {navLinks.map((link) => (
      <a 
        href={link.href} 
        class="text-2xl font-serif text-[#FDFBF7] hover:text-[#D4AF37] transition-colors mobile-nav-link"
      >
        {link.name}
      </a>
    ))}
    
    <div class="mt-8 flex flex-col gap-4 w-full">
      <a 
        href="/#booking-form" 
        class="w-full py-4 bg-[#D4AF37] hover:bg-[#F3E5AB] text-[#0a0a0a] text-center font-medium rounded-full transition-colors mobile-nav-link"
      >
        Book Appointment
      </a>
      <a 
        href={siteConfig.whatsappUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class="w-full py-4 bg-[#075E54] hover:bg-[#05433c] text-white text-center font-medium rounded-full transition-colors"
        style="text-shadow: 0 1px 2px rgba(0,0,0,0.8)"
      >
        Book on WhatsApp
      </a>
    </div>
  </nav>
  
  <div class="mt-auto text-center">
    <p class="text-sm text-[#FDFBF7]/50">{siteConfig.address}</p>
  </div>
</div>

<script>
  const header = document.getElementById('main-header');
  const logo = document.getElementById('header-logo');
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const overlay = document.getElementById('mobile-menu-overlay');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  // Handle header background & logo sizing on scroll
  const handleScroll = () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-[#D4AF37]/10', 'py-4', 'shadow-xl');
      header?.classList.remove('bg-transparent', 'py-6');
      logo?.classList.add('h-14', 'md:h-20');
      logo?.classList.remove('h-20', 'md:h-28');
    } else {
      header?.classList.remove('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-[#D4AF37]/10', 'py-4', 'shadow-xl');
      header?.classList.add('bg-transparent', 'py-6');
      logo?.classList.remove('h-14', 'md:h-20');
      logo?.classList.add('h-20', 'md:h-28');
    }
  };

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll(); // Init call

  // Toggle mobile menu overlay
  let isOpen = false;

  const toggleMenu = () => {
    isOpen = !isOpen;
    if (isOpen) {
      document.body.style.overflow = 'hidden';
      overlay?.classList.remove('-translate-y-full', 'opacity-0', 'pointer-events-none');
      overlay?.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
      hamburgerIcon?.classList.add('hidden');
      hamburgerIcon?.classList.remove('block');
      closeIcon?.classList.remove('hidden');
      closeIcon?.classList.add('block');
    } else {
      document.body.style.overflow = '';
      overlay?.classList.add('-translate-y-full', 'opacity-0', 'pointer-events-none');
      overlay?.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
      hamburgerIcon?.classList.remove('hidden');
      hamburgerIcon?.classList.add('block');
      closeIcon?.classList.add('hidden');
      closeIcon?.classList.remove('block');
    }
  };

  toggleBtn?.addEventListener('click', toggleMenu);

  // Close menu when links are clicked
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (isOpen) toggleMenu();
    });
  });
</script>

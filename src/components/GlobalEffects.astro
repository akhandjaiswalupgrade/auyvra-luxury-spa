<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
  <!-- Aurora / Steam Orbs (slow moving ambient colors) -->
  <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-[#0A1F1C]/25 rounded-full mix-blend-screen filter blur-[100px] md:blur-[150px] animate-aurora-1"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[60%] h-[60%] bg-[#D4AF37]/8 rounded-full mix-blend-screen filter blur-[120px] md:blur-[180px] animate-aurora-2"></div>
  
  <!-- Side Glow Flares (adds rich depth to the left and right edges) -->
  <div class="absolute top-0 left-0 w-[10vw] h-full bg-gradient-to-r from-[#D4AF37]/5 to-transparent opacity-80 animate-pulse-slow"></div>
  <div class="absolute top-0 right-0 w-[10vw] h-full bg-gradient-to-l from-[#0A1F1C]/30 to-transparent opacity-90"></div>
  
  <!-- Golden Bubble Canvas (fades in past the hero section) -->
  <canvas 
    id="global-bubbles-canvas" 
    class="absolute inset-0 w-full h-full opacity-0 transition-opacity duration-300"
  />
</div>

<style>
  @keyframes aurora-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(10%, 15%) scale(1.1); }
    66% { transform: translate(-5%, 5%) scale(0.9); }
  }
  @keyframes aurora-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-10%, -10%) scale(1.05); }
    66% { transform: translate(5%, -15%) scale(1.15); }
  }
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 0.9; }
  }
  .animate-aurora-1 { animation: aurora-1 25s ease-in-out infinite; }
  .animate-aurora-2 { animation: aurora-2 30s ease-in-out infinite reverse; }
  .animate-pulse-slow { animation: pulse-slow 8s ease-in-out infinite; }
</style>

<script>
  // Optimized particle bubble canvas
  const canvas = document.getElementById('global-bubbles-canvas') as HTMLCanvasElement | null;
  
  if (canvas && window.innerWidth >= 768) { // Completely disabled on mobile for TBT/INP savings
    const ctx = canvas.getContext('2d');
    
    if (ctx) {
      let animationFrameId: number | null = null;
      let particles: Particle[] = [];
      let isRunning = false;
      let scrollOpacity = 0;

      class Particle {
        x: number;
        y: number;
        size: number;
        speedY: number;
        speedX: number;
        opacity: number;
        glow: number;
        isLeftSide: boolean;
        
        constructor() {
          this.y = Math.random() * window.innerHeight;
          this.isLeftSide = Math.random() > 0.5;
          
          const sideWidth = window.innerWidth * 0.25;
          if (this.isLeftSide) {
            this.x = Math.random() * sideWidth;
          } else {
            this.x = window.innerWidth - (Math.random() * sideWidth);
          }

          this.size = Math.random() * 3 + 1;
          this.speedY = Math.random() * -0.4 - 0.15;
          this.speedX = (Math.random() * 0.15 - 0.075);
          this.opacity = Math.random() * 0.4 + 0.15;
          this.glow = Math.random() * 6 + 3;
        }
        
        update() {
          this.y += this.speedY;
          this.x += this.speedX;
          
          if (this.y < -10) {
            this.y = window.innerHeight + 10;
            const sideWidth = window.innerWidth * 0.25;
            if (this.isLeftSide) {
              this.x = Math.random() * sideWidth;
            } else {
              this.x = window.innerWidth - (Math.random() * sideWidth);
            }
          }
          
          const leftBound = window.innerWidth * 0.28;
          const rightBound = window.innerWidth * 0.72;
          
          if (this.isLeftSide && this.x > leftBound) {
            this.x = leftBound;
            this.speedX *= -1;
          }
          if (!this.isLeftSide && this.x < rightBound) {
            this.x = rightBound;
            this.speedX *= -1;
          }
        }
        
        draw() {
          if (!ctx) return;
          ctx.save();
          ctx.globalAlpha = this.opacity;
          
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
          
          const gradient = ctx.createRadialGradient(
            this.x - this.size * 0.2, 
            this.y - this.size * 0.2, 
            0, 
            this.x, 
            this.y, 
            this.size
          );
          gradient.addColorStop(0, '#FFFFFF');
          gradient.addColorStop(0.3, '#F3E5AB');
          gradient.addColorStop(1, '#D4AF37');
          
          ctx.fillStyle = gradient;
          ctx.shadowBlur = this.glow;
          ctx.shadowColor = '#D4AF37';
          ctx.fill();
          
          ctx.restore();
        }
      }

      const initParticles = () => {
        particles = [];
        const numBubbles = 55; 
        for (let i = 0; i < numBubbles; i++) {
          particles.push(new Particle());
        }
      };

      const animate = () => {
        if (!isRunning) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => {
          p.update();
          p.draw();
        });
        animationFrameId = requestAnimationFrame(animate);
      };

      const handleResize = () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        initParticles();
      };

      const startLoop = () => {
        if (!isRunning) {
          isRunning = true;
          animate();
        }
      };

      const stopLoop = () => {
        if (isRunning) {
          isRunning = false;
          if (animationFrameId) {
            cancelAnimationFrame(animationFrameId);
            animationFrameId = null;
          }
        }
      };

      const handleScroll = () => {
        const threshold = window.innerHeight * 0.7;
        const currentScroll = window.scrollY;
        
        if (currentScroll < threshold) {
          if (scrollOpacity !== 0) {
            scrollOpacity = 0;
            canvas.style.opacity = '0';
            stopLoop(); // Suspend particle loop when hidden
          }
        } else {
          const newOpacity = Math.min(1, (currentScroll - threshold) / 200);
          if (scrollOpacity !== newOpacity) {
            scrollOpacity = newOpacity;
            canvas.style.opacity = String(newOpacity);
          }
          startLoop(); // Resume particle loop when visible
        }
      };

      window.addEventListener('resize', handleResize, { passive: true });
      window.addEventListener('scroll', handleScroll, { passive: true });
      
      handleResize();
      handleScroll();
    }
  } else if (canvas) {
    // On mobile, completely hide/remove canvas element to avoid render overhead
    canvas.style.display = 'none';
  }
</script>
